# Copia a .env y rellena. Nunca subas .env al repositorio.

# Obligatorio salvo que en local pongas ALLOW_OPEN_ADMIN_ROUTES=1 (solo máquina de confianza).
ADMIN_API_TOKEN=cambia-esto-por-un-secreto-largo-aleatorio

# Orígenes del navegador permitidos (coma-separados). Incluye tu dominio de producción.
CORS_ALLOWED_ORIGINS=http://localhost:4321

# URL pública de la API tal como la ve el navegador (frontend).
PUBLIC_API_URL=http://localhost:13100

# 1 = lanzar sync al arrancar el contenedor api (más carga al inicio).
# SCRAPE_ON_START=0

# Solo desarrollo local: desprotege /refresh, /sync, etc. (no usar si el puerto es accesible en red).
# ALLOW_OPEN_ADMIN_ROUTES=1
