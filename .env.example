# ==============================================================================
#  Copia a .env y ajusta. En LOCAL suele bastar con PUBLIC_API_URL.
# ==============================================================================

TZ=Europe/Madrid
HOST_PORT=13100
FRONTEND_PORT=4321
SCRAPE_ON_START=1

# --- LOCAL (mismo PC) -------------------------------------------------------
# El frontend en Docker usa API_URL=http://api:13100 (red interna).
# Solo cambia esto si el navegador no es localhost (otro dispositivo en la LAN):
# PUBLIC_API_URL=http://localhost:13100
# PUBLIC_API_URL=http://192.168.1.128:13100

# --- Seguridad API (recomendado incluso en local) ----------------------------
# ADMIN_API_TOKEN=   # openssl rand -hex 32  — obligatorio para /refresh, /sync, etc.
# ALLOW_OPEN_ADMIN_ROUTES=1   # solo si quieres esas rutas abiertas sin token (máquina aislada)

# --- LOCAL avanzado (opcional) ----------------------------------------------
# APP_ENV=development
# CORS_ALLOWED_ORIGINS=http://localhost:4321,http://127.0.0.1:4321
# En desarrollo el API usa CORS * por defecto; esta lista solo aplica si pasas a APP_ENV=production en el mismo compose.

# --- VPS / PRODUCCIÓN (docker-compose.prod.yml) ------------------------------
# NOTICIAS_API_IMAGE=ghcr.io/tu-org/noticias-api:1.0.0
# NOTICIAS_FRONTEND_IMAGE=ghcr.io/tu-org/noticias-frontend:1.0.0
# URL pública del API (HTTPS recomendado). Debe coincidir con lo que el navegador usa.
# PUBLIC_API_URL=https://api.tudominio.com
# Secreto largo para /refresh, /sync, /enrich, /cleanup y variantes (Authorization: Bearer …)
# ADMIN_API_TOKEN=
# Orígenes del frontend permitidos en CORS (separados por coma). Vacío = sin wildcard en prod.
# Ejemplo si el sitio público es https://noticias.tudominio.com :
# CORS_ALLOWED_ORIGINS=https://noticias.tudominio.com
