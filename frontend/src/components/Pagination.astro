---
import { UI_TEXT } from "../lib/constants";
import { type PageState, buildUrl } from "../lib/url";

interface Props {
  state: PageState;
  totalPages: number;
}

const { state, totalPages } = Astro.props;
const { page, language } = state;
const t = UI_TEXT[language];

/**
 * Devuelve una lista compacta de páginas con elipsis:
 * 1 … 4 5 [6] 7 8 … 21
 */
const getPageItems = (current: number, total: number): (number | "…")[] => {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const items: (number | "…")[] = [];
  const window = 1;

  items.push(1);
  if (current - window > 2) items.push("…");

  const start = Math.max(2, current - window);
  const end = Math.min(total - 1, current + window);
  for (let i = start; i <= end; i += 1) items.push(i);

  if (current + window < total - 1) items.push("…");
  items.push(total);

  return items;
};

const pages = getPageItems(page, totalPages);
const hasPrev = page > 1;
const hasNext = page < totalPages;
---

{
  totalPages > 1 && (
    <nav class="pagination" aria-label="Paginación">
      <a
        href={hasPrev ? buildUrl(state, { page: page - 1 }) : "#"}
        class:list={["pagination__arrow", !hasPrev && "is-disabled"]}
        aria-disabled={hasPrev ? undefined : "true"}
        rel={hasPrev ? "prev" : undefined}
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M15 6l-6 6 6 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
        <span>{t.previous}</span>
      </a>

      <ul class="pagination__pages" role="list">
        {pages.map((p) =>
          p === "…" ? (
            <li class="pagination__ellipsis" aria-hidden="true">
              …
            </li>
          ) : (
            <li>
              <a
                href={buildUrl(state, { page: p })}
                class:list={["pagination__page", p === page && "is-active"]}
                aria-current={p === page ? "page" : undefined}
              >
                {p}
              </a>
            </li>
          ),
        )}
      </ul>

      <a
        href={hasNext ? buildUrl(state, { page: page + 1 }) : "#"}
        class:list={["pagination__arrow", !hasNext && "is-disabled"]}
        aria-disabled={hasNext ? undefined : "true"}
        rel={hasNext ? "next" : undefined}
      >
        <span>{t.next}</span>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M9 6l6 6-6 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </a>
    </nav>
  )
}

<style>
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 48px;
  }

  .pagination__pages {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .pagination__page {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    border-radius: var(--ps-r-pill);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--ps-charcoal);
    text-decoration: none;
    background: transparent;
    border: 1px solid transparent;
    transition: background var(--ps-dur) var(--ps-ease),
      color var(--ps-dur) var(--ps-ease),
      border-color var(--ps-dur) var(--ps-ease),
      box-shadow var(--ps-dur) var(--ps-ease), transform var(--ps-dur) var(--ps-ease);
  }

  .pagination__page:hover,
  .pagination__page:focus-visible {
    background: var(--ps-cyan);
    color: var(--ps-inverse);
    border-color: var(--ps-inverse);
    box-shadow: 0 0 0 2px var(--ps-blue);
    transform: scale(1.08);
  }

  .pagination__page.is-active {
    background: var(--ps-blue);
    color: var(--ps-inverse);
  }
  .pagination__page.is-active:hover {
    background: var(--ps-cyan);
  }

  .pagination__ellipsis {
    min-width: 24px;
    text-align: center;
    color: var(--ps-body-gray);
    font-weight: 500;
  }

  .pagination__arrow {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border-radius: var(--ps-r-pill);
    background: var(--ps-paper);
    border: 1px solid #dedede;
    color: var(--ps-charcoal);
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.1px;
    text-decoration: none;
    transition: background var(--ps-dur) var(--ps-ease),
      color var(--ps-dur) var(--ps-ease),
      border-color var(--ps-dur) var(--ps-ease),
      transform var(--ps-dur) var(--ps-ease);
  }
  .pagination__arrow:hover,
  .pagination__arrow:focus-visible {
    background: var(--ps-cyan);
    border-color: var(--ps-inverse);
    color: var(--ps-inverse);
    box-shadow: 0 0 0 2px var(--ps-blue);
    transform: scale(1.04);
  }

  .pagination__arrow.is-disabled {
    pointer-events: none;
    opacity: 0.4;
    background: transparent;
  }
</style>
