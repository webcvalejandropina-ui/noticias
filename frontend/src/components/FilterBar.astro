---
import type { Category, Language } from "../lib/types";
import { CATEGORIES_BY_LANG, UI_TEXT, categoryLabel } from "../lib/constants";
import { type PageState, buildUrl } from "../lib/url";

interface Props {
  state: PageState;
  sources: string[];
  apiUrl: string;
}

const { state, sources, apiUrl } = Astro.props;
const { language, category, q, source, view } = state;
const t = UI_TEXT[language];

const availableCategories = CATEGORIES_BY_LANG[language];
const hasFilters = Boolean(q || source);
const isDigest = view === "digest";
const isGeneral = view === "general";
const isList = view === "list";
---

<section class="filters" aria-label="Filtros de búsqueda">
  <div class="container filters__inner">
    <nav class="filters__categories" aria-label="Categorías">
      {
        CATEGORIES_BY_LANG[language].length > 1 && (
          <a
            href={buildUrl(state, { view: "general" })}
            class:list={["ps-pill", "filters__general-pill", isGeneral && "is-active"]}
            aria-current={isGeneral ? "page" : undefined}
          >
            <span class="filters__general-dot" aria-hidden="true" />
            {t.general}
          </a>
        )
      }

      {
        CATEGORIES_BY_LANG[language].length > 1 && (
          <a
            href={buildUrl(state, { view: "digest" })}
            class:list={["ps-pill", "filters__digest-pill", isDigest && "is-active"]}
            aria-current={isDigest ? "page" : undefined}
          >
            <span class="filters__digest-dot" aria-hidden="true" />
            {t.digest}
          </a>
        )
      }

      {
        availableCategories.map((cat: Category) => (
          <a
            href={buildUrl(state, { view: "list", category: cat, page: 1 })}
            class:list={["ps-pill", isList && cat === category && "is-active"]}
            aria-current={isList && cat === category ? "page" : undefined}
          >
            {categoryLabel(cat, language)}
          </a>
        ))
      }
    </nav>

    {
      isList && (
        <form class="filters__form" method="get" action="/" role="search">
          <input type="hidden" name="lang" value={language} />
          <input type="hidden" name="cat" value={category} />

          <label class="filters__search">
            <span class="visually-hidden">{t.search}</span>
            <svg
              class="filters__search-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <circle
                cx="11"
                cy="11"
                r="7"
                stroke="currentColor"
                stroke-width="2"
              />
              <path
                d="M20 20l-3.5-3.5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
              />
            </svg>
            <input
              type="search"
              name="q"
              class="ps-input filters__input"
              placeholder={t.searchPlaceholder}
              value={q}
              autocomplete="off"
            />
          </label>

          {sources.length > 1 && (
            <select
              name="source"
              class="ps-select filters__select"
              aria-label={t.allSources}
            >
              <option value="">{t.allSources}</option>
              {sources.map((s) => (
                <option value={s} selected={s === source}>
                  {s}
                </option>
              ))}
            </select>
          )}

          <button type="submit" class="ps-btn ps-btn--mini filters__submit">
            {t.search}
          </button>

          <button
            type="button"
            class="ps-btn ps-btn--mini filters__sync js-sync-btn"
            data-api-url={apiUrl}
            data-label={t.sync}
            data-label-running={t.syncRunning}
            data-label-ok={t.syncOk}
            data-label-error={t.syncError}
            title={t.syncTitle}
            aria-label={t.sync}
          >
            <svg
              class="filters__sync-icon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M4 12a8 8 0 0 1 14-5.3L20 5m0 0v5h-5M20 12a8 8 0 0 1-14 5.3L4 19m0 0v-5h5"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
            <span class="filters__sync-label">{t.sync}</span>
          </button>

          {hasFilters && (
            <a
              href={buildUrl(state, { q: "", source: "", page: 1 })}
              class="filters__clear"
            >
              {t.clearFilters}
            </a>
          )}
        </form>
      )
    }
  </div>
</section>

<script>
  const SYNC_RELOAD_DELAY_MS = 900;
  const SYNC_ERROR_RESET_MS = 3200;

  document
    .querySelectorAll<HTMLButtonElement>(".js-sync-btn")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const rawUrl = btn.dataset.apiUrl;
        if (!rawUrl) return;

        const apiBase = rawUrl.replace(/\/+$/, "");
        const labelEl = btn.querySelector<HTMLSpanElement>(
          ".filters__sync-label",
        );
        const original = btn.dataset.label ?? labelEl?.textContent ?? "Sync";
        const running = btn.dataset.labelRunning ?? original;
        const ok = btn.dataset.labelOk ?? original;
        const error = btn.dataset.labelError ?? original;

        btn.disabled = true;
        btn.classList.remove("is-ok", "is-error");
        btn.classList.add("is-running");
        if (labelEl) labelEl.textContent = running;

        try {
          const res = await fetch(`${apiBase}/sync`, {
            method: "GET",
            headers: { Accept: "application/json" },
            cache: "no-store",
          });
          if (!res.ok) {
            throw new Error(`HTTP ${res.status}`);
          }
          btn.classList.remove("is-running");
          btn.classList.add("is-ok");
          if (labelEl) labelEl.textContent = ok;
          setTimeout(() => {
            window.location.reload();
          }, SYNC_RELOAD_DELAY_MS);
        } catch (err) {
          console.error("[sync] fallo", err);
          btn.classList.remove("is-running");
          btn.classList.add("is-error");
          if (labelEl) labelEl.textContent = error;
          setTimeout(() => {
            btn.disabled = false;
            btn.classList.remove("is-error");
            if (labelEl) labelEl.textContent = original;
          }, SYNC_ERROR_RESET_MS);
        }
      });
    });
</script>

<style>
  .filters {
    position: sticky;
    top: 64px;
    z-index: 15;
    background: var(--ps-filter-mist);
    backdrop-filter: saturate(180%) blur(16px);
    -webkit-backdrop-filter: saturate(180%) blur(16px);
    border-bottom: 1px solid var(--ps-divider);
  }

  .filters__inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px 24px;
  }

  .filters__categories {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .filters__digest-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
  }

  .filters__digest-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--ps-cyan);
    box-shadow: 0 0 0 3px rgba(0, 207, 228, 0.2);
  }

  .filters__general-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
  }

  .filters__general-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ff3964, #7b5cff 60%, #00cfe4);
    box-shadow: 0 0 0 3px rgba(123, 92, 255, 0.22);
  }

  .filters__form {
    display: grid;
    grid-template-columns: 1fr auto auto auto auto;
    gap: 12px;
    align-items: center;
  }

  .filters__search {
    position: relative;
    display: block;
  }

  .filters__search-icon {
    position: absolute;
    left: 14px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--ps-body-gray);
    pointer-events: none;
  }

  .filters__input {
    padding-left: 42px;
  }

  .filters__select {
    min-width: 180px;
  }

  .filters__submit {
    white-space: nowrap;
  }

  .filters__sync {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
  }

  .filters__sync[disabled] {
    cursor: progress;
    opacity: 0.75;
  }

  .filters__sync-icon {
    transition: transform 0.6s var(--ps-ease);
  }

  .filters__sync.is-running .filters__sync-icon {
    animation: filters-sync-spin 0.9s linear infinite;
  }

  .filters__sync.is-ok {
    background: rgba(30, 162, 96, 0.15);
    border-color: rgba(30, 162, 96, 0.45);
    color: #1ea260;
  }

  .filters__sync.is-error {
    background: rgba(200, 27, 58, 0.12);
    border-color: rgba(200, 27, 58, 0.4);
    color: var(--ps-warning);
  }

  @keyframes filters-sync-spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  .filters__clear {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--ps-body-gray);
    padding: 4px 8px;
    border-radius: var(--ps-r-6);
    text-decoration: none;
    transition: color var(--ps-dur) var(--ps-ease);
  }
  .filters__clear:hover {
    color: var(--ps-warning);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .filters__form {
      grid-template-columns: 1fr 1fr auto;
    }
    .filters__search {
      grid-column: 1 / -1;
    }
    .filters__select {
      min-width: 0;
    }
    .filters__sync {
      justify-self: end;
    }
  }

  @media (max-width: 540px) {
    .filters__form {
      grid-template-columns: 1fr;
    }
    .filters__select {
      width: 100%;
    }
    .filters__sync {
      width: 100%;
      justify-content: center;
      justify-self: stretch;
    }
  }
</style>
