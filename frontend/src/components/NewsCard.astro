---
import type { Language, NewsItem } from "../lib/types";
import { UI_TEXT, categoryLabel } from "../lib/constants";

interface Props {
  item: NewsItem;
  language: Language;
  eager?: boolean;
  showCategory?: boolean;
}

const { item, language, eager = false, showCategory = true } = Astro.props;
const t = UI_TEXT[language];
const catLabel = showCategory && item.category ? categoryLabel(item.category, language) : "";

const formatDate = (iso: string): string => {
  try {
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return "";
    return new Intl.DateTimeFormat(language === "es" ? "es-ES" : "en-US", {
      day: "2-digit",
      month: "short",
      year: "numeric",
    }).format(d);
  } catch {
    return "";
  }
};

const date = formatDate(item.pubDate);
---

<article class="news-card">
  <a
    href={item.link}
    class="news-card__link"
    target="_blank"
    rel="noopener noreferrer"
    aria-label={item.title}
  >
    <div class="news-card__media">
      <img
        src={item.image}
        alt=""
        loading={eager ? "eager" : "lazy"}
        decoding="async"
        referrerpolicy="no-referrer"
      />
      {catLabel && (
        <span
          class:list={["ps-tag", "news-card__category", `news-card__category--${item.category}`]}
          aria-label={catLabel}
        >
          {catLabel}
        </span>
      )}
    </div>

    <div class="news-card__body">
      <div class="news-card__meta">
        <span class="ps-tag ps-tag--blue">{item.source}</span>
        {date && <span class="news-card__date">{date}</span>}
      </div>

      <h3 class="news-card__title">{item.title}</h3>
      {
        item.description && (
          <p class="news-card__description">{item.description}</p>
        )
      }

      <span class="news-card__cta">
        {t.readMore}
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M5 12h14M13 6l6 6-6 6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
    </div>
  </a>
</article>

<style>
  .news-card {
    display: flex;
    height: 100%;
  }

  .news-card__link {
    display: flex;
    flex-direction: column;
    width: 100%;
    background: var(--ps-paper);
    color: var(--ps-charcoal);
    border-radius: var(--ps-r-19);
    overflow: hidden;
    text-decoration: none;
    box-shadow: var(--ps-shadow-06);
    transition: box-shadow var(--ps-dur) var(--ps-ease),
      transform var(--ps-dur) var(--ps-ease);
  }

  .news-card__link:hover,
  .news-card__link:focus-visible {
    box-shadow: var(--ps-shadow-16);
    transform: translateY(-4px);
    color: var(--ps-charcoal);
  }

  .news-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--ps-mist);
  }

  .news-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 400ms var(--ps-ease);
  }

  .news-card__link:hover .news-card__media img,
  .news-card__link:focus-visible .news-card__media img {
    transform: scale(1.04);
  }

  .news-card__category {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 1;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 999px;
    backdrop-filter: saturate(160%) blur(8px);
    -webkit-backdrop-filter: saturate(160%) blur(8px);
    background: rgba(6, 10, 15, 0.72);
    color: #fff;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.2);
  }

  .news-card__category--ia {
    background: linear-gradient(135deg, #00cfe4 0%, #0072ce 100%);
  }
  .news-card__category--futbol {
    background: linear-gradient(135deg, #11b886 0%, #046a4d 100%);
  }
  .news-card__category--internacional {
    background: linear-gradient(135deg, #7b5cff 0%, #2b1d8a 100%);
  }
  .news-card__category--tecnologia {
    background: linear-gradient(135deg, #ff8c00 0%, #c8371c 100%);
  }
  .news-card__category--software {
    background: linear-gradient(135deg, #ffc53d 0%, #c8361d 100%);
    color: #1a0d00;
  }
  .news-card__category--hack {
    background: linear-gradient(135deg, #ff3964 0%, #6a0a2b 100%);
  }
  .news-card__category--cine {
    background: linear-gradient(135deg, #ff4d94 0%, #5b1a6b 100%);
  }
  .news-card__category--medios-int {
    background: linear-gradient(135deg, #5fb0ff 0%, #0f3d8a 100%);
  }

  .news-card__body {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 20px 20px 24px;
    flex: 1;
  }

  .news-card__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .news-card__date {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ps-body-gray);
    letter-spacing: 0.1px;
  }

  .news-card__title {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 500;
    line-height: 1.3;
    color: var(--ps-ink);
    letter-spacing: 0.1px;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__description {
    margin: 0;
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.5;
    color: var(--ps-body-gray);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .news-card__cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--ps-blue);
    letter-spacing: 0.324px;
    transition: color var(--ps-dur) var(--ps-ease),
      gap var(--ps-dur) var(--ps-ease);
  }

  .news-card__link:hover .news-card__cta,
  .news-card__link:focus-visible .news-card__cta {
    color: var(--ps-link-hover);
    gap: 10px;
  }
</style>
